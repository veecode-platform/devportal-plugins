{
  "name": "devportal-marketplace-backend",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "extensions",
    "pluginPackages": [
      "devportal-marketplace-backend"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "tsc": "tsc",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "export-dynamic": "YARN_ENABLE_IMMUTABLE_INSTALLS=false rhdh-cli plugin export --embed-package @red-hat-developer-hub/backstage-plugin-extensions-common",
    "export-dynamic:clean": "YARN_ENABLE_IMMUTABLE_INSTALLS=false rhdh-cli plugin export --clean --embed-package @red-hat-developer-hub/backstage-plugin-extensions-common"
  },
  "dependencies": {
    "@backstage/backend-defaults": "^0.16.0",
    "@backstage/backend-dynamic-feature-service": "^0.8.0",
    "@backstage/backend-plugin-api": "^1.8.0",
    "@backstage/catalog-client": "^1.15.0",
    "@backstage/catalog-model": "^1.7.7",
    "@backstage/errors": "^1.2.7",
    "@backstage/plugin-permission-common": "^0.9.7",
    "@backstage/plugin-permission-node": "^0.10.11",
    "@red-hat-developer-hub/backstage-plugin-extensions-common": "^0.15.0",
    "express": "^4.17.1",
    "express-promise-router": "^4.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/config": "^1.3.6",
    "@backstage/types": "^1.2.2",
    "@red-hat-developer-hub/cli": "latest",
    "typescript": "~5.8.0"
  },
  "files": [
    "dist",
    "migrations"
  ]
}
